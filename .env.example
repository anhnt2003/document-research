# Copy this file to `.env` and fill in real values. NEVER commit .env.

# --- Postgres (shared by core + api) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=document_research
POSTGRES_USER=postgres
POSTGRES_PASSWORD=dev
# SQLAlchemy / EF Core read this directly when set:
DATABASE_URL=postgresql+psycopg://postgres:dev@localhost:5432/document_research

# --- MinIO (object storage for document binaries; backend/api uses these) ---
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=documents

# --- Anthropic API (backend/core, LLM) ---
ANTHROPIC_API_KEY=

# --- Google OAuth + JWT (backend/api, auth) ---
# Web client ID from Google Cloud Console; matches `aud` claim in ID tokens from the SPA.
GOOGLE_CLIENT_ID=
# HS256 signing key for the API's own JWT; min 32 bytes, rotate per environment.
AUTH_JWT_SIGNING_KEY=

# --- App config ---
APP_ENV=development
LOG_LEVEL=INFO
CORE_PORT=8000
API_PORT=5000
FRONTEND_PORT=4200
