    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(dotnet ef database drop*)",
      "Bash(docker compose down -v*)",
      "Bash(docker volume rm*)"
    ]
  }
}
